{
  "expo": {
    "name": "Alchono",
    "slug": "alchono",
    "scheme": "alchono",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Splash_Screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#2A2733"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alchono.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Alchono uses camera for profile photos.",
        "NSPhotoLibraryUsageDescription": "Alchono uses photo library for profile photos.",
        "NSMicrophoneUsageDescription": "Alchono uses the microphone to record private voice journal notes.",
        "NSLocationWhenInUseUsageDescription": "Alchono uses your approximate location to show community posts from people near you. Your location is never shown to anyone.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": ["group.com.alchono.app"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2A2733"
      },
      "package": "com.alchono.app",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "RECORD_AUDIO",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#A489DE",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/Splash_Screen.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#2A2733"
        }
      ],
      "expo-font",
      [
        "@bacons/apple-targets",
        {
          "appleTeamId": "6R7SGGG57X"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
